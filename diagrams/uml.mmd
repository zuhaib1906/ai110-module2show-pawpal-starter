classDiagram
    class Owner {
        +string owner_name
        +list~string~ pet_names
        +add_owner()
        +edit_owner()
        +delete_owner()
        +add_pet(pet_name)
    }

    class Pet {
        +string pet_name
        +string owner_name
        +add_pet()
        +edit_pet()
        +delete_pet()
    }

    class Task {
        +string task_name
        +string pet_name
        +int duration
        +string priority
        +add_task()
        +set_duration_and_priority()
        +edit_task()
        +delete_task()
        +display_tasks_for_day(day)
    }

    class Scheduler {
        +list~Task~ tasks
        +string pet_name
        +generate_schedule()
        +display_schedule()
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "*" Task : schedules

