classDiagram
    class Task {
        +str task_name
        +str pet_name
        +int duration
        +str priority
        +str|None start_time
        +str recurrence
        +str|None day
        +bool completed
        +mark_complete() None
        +set_duration_and_priority(duration, priority) None
        +edit_task(**changes) None
        +next_occurrence() Task|None
        +occurs_on(day) bool
    }

    class Pet {
        +str pet_name
        +str owner_name
        +list~Task~ tasks
        +add_task(task) None
        +edit_task(task_name, **changes) None
        +delete_task(task_name) None
    }

    class Owner {
        +str owner_name
        +list~Pet~ pets
        +int available_minutes
        +dict preferences
        +add_pet(pet) None
        +edit_pet(pet_name, **changes) None
        +delete_pet(pet_name) None
        +all_tasks() list~Task~
    }

    class Scheduler {
        -int _NO_TIME$
        -dict _PRIORITY$
        +Owner owner
        +str reasoning
        +__init__(owner)
        -_to_minutes(start_time) int
        -_priority_rank(priority) int
        +complete_task(task) Task|None
        +filter_tasks(tasks, pet_name, status) list~Task~
        +sort_by_time(tasks) list~Task~
        +find_conflicts(tasks) list~dict~
        +conflict_warning(tasks) str
        +generate_schedule(day, pet_name, status) list~Task~
        +display_schedule(day) None
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : plans for
